{
  "name": "ngx-notitia",
  "version": "1.0.0",
  "description": "Easy, flexible toast notifications for Angular",
  "keywords": [
    "angular",
    "toast",
    "notification",
    "toastr",
    "alert",
    "snackbar"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0",
    "rxjs": "^7.8.2"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/klajdm/ngx-notitia"
  },
  "exports": {
    "./toastr": {
      "default": "./toastr.css"
    },
    "./toastr-old": {
      "default": "./toastr-old.css"
    },
    "./toastr-bs4-alert": {
      "default": "./toastr-bs4-alert.scss"
    },
    "./toastr-bs5-alert": {
      "default": "./toastr-bs5-alert.scss"
    }
  },
  "sideEffects": false
}
